# See docs/devel/tracing.rst for syntax documentation.

# arch/exception.c
ia64_exception_raise(int cpu_index, uint32_t exception, uint64_t ip, uint64_t immediate, uint32_t slot, uint64_t isr) "cpu=%d exception=%" PRIu32 " ip=0x%016" PRIx64 " imm=0x%016" PRIx64 " slot=%" PRIu32 " isr=0x%016" PRIx64
ia64_exception_deliver(int cpu_index, uint32_t exception, uint64_t vector, uint64_t ip, uint64_t fault_address, uint32_t slot, uint64_t isr, bool collect) "cpu=%d exception=%" PRIu32 " vector=0x%04" PRIx64 " ip=0x%016" PRIx64 " fault=0x%016" PRIx64 " slot=%" PRIu32 " isr=0x%016" PRIx64 " collect=%d"

# arch/interrupt.c
ia64_sapic_vector(int cpu_index, const char *operation, int vector) "cpu=%d operation=%s vector=%d"
ia64_itm(int cpu_index, const char *operation, uint64_t itc, uint64_t itm, int vector) "cpu=%d operation=%s itc=0x%016" PRIx64 " itm=0x%016" PRIx64 " vector=%d"

# arch/mmu.c
ia64_mmu_purge(int cpu_index, const char *operation, uint64_t va, uint64_t page_size, uint32_t rid, uint32_t mode) "cpu=%d operation=%s va=0x%016" PRIx64 " page_size=0x%016" PRIx64 " rid=0x%06" PRIx32 " mode=%" PRIu32
ia64_mmu_serialize(int cpu_index, uint32_t data, uint32_t instruction, uint32_t pending, bool targeted) "cpu=%d data=%" PRIu32 " instruction=%" PRIu32 " pending=%" PRIu32 " targeted=%d"

# arch/rse.c
ia64_rse_state(int cpu_index, const char *operation, uint64_t bsp, uint64_t bspstore, int32_t dirty, int32_t dirty_nat, int32_t clean, int32_t clean_nat, int32_t invalid, uint32_t sof) "cpu=%d operation=%s bsp=0x%016" PRIx64 " bspstore=0x%016" PRIx64 " dirty=%" PRId32 "/%" PRId32 " clean=%" PRId32 "/%" PRId32 " invalid=%" PRId32 " sof=%" PRIu32

# arch/pal.c
ia64_pal_call(int cpu_index, uint64_t index, uint64_t arg0, uint64_t arg1, uint64_t arg2) "cpu=%d index=0x%03" PRIx64 " args=0x%016" PRIx64 ",0x%016" PRIx64 ",0x%016" PRIx64
ia64_pal_return(int cpu_index, uint64_t index, int64_t status, uint64_t result1, uint32_t flags) "cpu=%d index=0x%03" PRIx64 " status=%" PRId64 " result1=0x%016" PRIx64 " flags=0x%x"

# arch/fp.c
ia64_fpswa_call(int cpu_index, uint64_t trap_type, uint64_t bundle, bool pending) "cpu=%d trap_type=%" PRIu64 " bundle=0x%016" PRIx64 " pending=%d"
ia64_fpswa_return(int cpu_index, int64_t status, uint64_t err1, uint64_t err2, uint64_t err3) "cpu=%d status=%" PRId64 " err=0x%016" PRIx64 ",0x%016" PRIx64 ",0x%016" PRIx64
